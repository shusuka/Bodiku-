rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: Open access - cocok untuk internal tool tanpa auth.
    // Kalau mau lebih aman, aktifkan Firebase Auth dan ubah ke:
    //   allow read, write: if request.auth != null;
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
